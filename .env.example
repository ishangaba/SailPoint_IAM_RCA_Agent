# ── IIQ Connection ──────────────────────────────────────────────────────────
# Set IIQ_USE_MOCK=true to point at mock server instead of real IIQ
IIQ_USE_MOCK=true
IIQ_BASE_URL=https://your-iiq-server:8443/identityiq
IIQ_USERNAME=svc_api_integration
IIQ_PASSWORD=your-strong-password-here
IIQ_TIMEOUT_SECONDS=10
IIQ_MAX_RETRIES=3

# ── Mock Server (used when IIQ_USE_MOCK=true) ─────────────────────────────
MOCK_IIQ_URL=http://localhost:3001
MOCK_SERVICENOW_URL=http://localhost:3002
MOCK_PORT=3001

# ── ServiceNow Connection ──────────────────────────────────────────────────
SNOW_BASE_URL=https://your-instance.service-now.com
SNOW_USERNAME=svc_rca_agent
SNOW_PASSWORD=your-servicenow-password
SNOW_IAM_ASSIGNMENT_GROUP=IAM-Ops-Team
SNOW_L3_ASSIGNMENT_GROUP=IAM-L3-Team

# ── MCP Server ────────────────────────────────────────────────────────────
MCP_SERVER_PORT=3000
MCP_SERVER_HOST=localhost

# ── Cache ─────────────────────────────────────────────────────────────────
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379

# ── Agent ─────────────────────────────────────────────────────────────────
AGENT_PORT=8000

# ── High-Risk Applications (comma-separated) ─────────────────────────────
HIGH_RISK_APPLICATIONS=Active Directory,SAP ECC,AWS Production,GitHub Enterprise,Okta

# ── Hybrid Agent Tuning ───────────────────────────────────────────────────
# Confidence threshold below which the agent uses open reasoning instead of
# the guided decision tree. Range: 0.0–1.0 (default: 0.75)
CONFIDENCE_THRESHOLD_GUIDED=0.75
# Hard cap on additional tool calls in the adaptive tier (default: 10)
MAX_ADAPTIVE_TOOL_CALLS=10
# Hard cap on tool calls in the open reasoning tier (default: 20)
MAX_OPEN_REASONING_TOOL_CALLS=20
