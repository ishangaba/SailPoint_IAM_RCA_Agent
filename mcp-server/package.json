{
  "name": "iiq-mcp-server",
  "version": "1.0.0",
  "description": "MCP server exposing 12 SailPoint IdentityIQ tools",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:@modelcontextprotocol/sdk --external:axios --external:zod --external:dotenv",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.7",
    "dotenv": "^16.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.27.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
